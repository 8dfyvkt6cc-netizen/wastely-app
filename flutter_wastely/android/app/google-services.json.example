{
  "_INSTRUCTIONS": "Replace this file with your actual google-services.json from Firebase Console. Steps: 1) Go to https://console.firebase.google.com 2) Create a project 'wastely' 3) Add Android app with package name 'com.wastely.app' 4) Download google-services.json and replace this file 5) Enable Authentication → Email/Password in Firebase Console",
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "wastely-app",
    "storage_bucket": "wastely-app.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "1:YOUR_PROJECT_NUMBER:android:YOUR_APP_ID",
        "android_client_info": {
          "package_name": "com.wastely.app"
        }
      },
      "oauth_client": [],
      "api_key": [
        {
          "current_key": "YOUR_API_KEY"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
